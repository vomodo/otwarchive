# ============================================================
# AO3 Vietnam — Production Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

# --- Database ---
DB_ROOT_PASSWORD=change_me_strong_root_password
DB_PASSWORD=change_me_strong_user_password
DB_HOST=db
DB_PORT=3306
DB_NAME=ao3_production
DB_USER=ao3_user

# Rails dùng DATABASE_URL (override database.yml)
DATABASE_URL=mysql2://ao3_user:change_me_strong_user_password@db:3306/ao3_production

# --- Rails ---
RAILS_ENV=production
SECRET_KEY_BASE=generate_with__bundle_exec_rails_secret

# Active Record Encryption (generate: bundle exec rails db:encryption:init)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# --- Cache & Queue ---
REDIS_URL=redis://redis:6379/0
RESQUE_REDIS_URL=redis://redis:6379/0
MEMCACHE_SERVERS=mc:11211

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://es:9200

# --- Email (Resend SMTP) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@ao3.ducvu.vn
SMTP_DOMAIN=ao3.ducvu.vn

# --- App Config ---
AO3_HOST=ao3.ducvu.vn
AO3_PROTOCOL=https

# --- Devise ---
DEVISE_SECRET_KEY=generate_with__bundle_exec_rails_secret
